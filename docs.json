{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SoftSol",
  "colors": {
    "primary": "#ffffff",
    "light": "#ffffff",
    "dark": "#ffffff"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "favicon": "/logo/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index"
            ]
          },
          {
            "group": "Player Account Management",
            "pages": [
              "contracts/pam/overview",
              "contracts/pam/initialize-platform",
              "contracts/pam/place",
              "contracts/pam/receive-entropy",
              "contracts/pam/settle"
            ]
          },
          {
            "group": "Pricing",
            "pages": [
              "contracts/pricing/overview",
              "contracts/pricing/publish-option",
              "contracts/pricing/get-quote",
              "contracts/pricing/swap"
            ]
          },
          {
            "group": "Staking",
            "pages": [
              "contracts/staking/overview",
              "contracts/staking/stake",
              "contracts/staking/claim",
              "contracts/staking/unstake"
            ]
          },
          {
            "group": "Resolution",
            "pages": [
              "contracts/resolution/overview",
              "contracts/resolution/optimistic-oracle",
              "contracts/resolution/external-feeds"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "contracts/resources/addresses",
              "contracts/resources/fees"
            ]
          }
        ]
      }
    ],
    "global": {}

  },
  "logo": {
    "light": "/logo/logo.svg",
    "dark": "/logo/logo.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Changelog",
        "href": "/changelog"
      },
      {
        "label": "Support",
        "href": "mailto:hi@softsol.xyz"
      }
    ]
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "metadata": {
    "og:image": "/logo/og.png"
  },
  "footer": {
    "socials": {
      "x": "https://x.com/softsolxyz",
      "github": "https://github.com/softsolana"
    }
  }
}
